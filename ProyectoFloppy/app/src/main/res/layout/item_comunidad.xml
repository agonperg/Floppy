<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/gris_fondo_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/lila_suave"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="@color/lila_suave"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tvLetraComunidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="#8A67CE"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="D" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreComunidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/corporativo"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Derecho" />

            <TextView
                android:id="@+id/tvUbicacionComunidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#5C7B96"
                android:textSize="14sp"
                tools:text="Universidad de Jaén" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>